{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "kill-kava",
      "type": "shell",
      "command": "taskkill /F /IM Kava.Desktop.exe 2>$null; Start-Sleep -Seconds 1; exit 0",
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "build-kava",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Kava/src/Kava.Desktop/Kava.Desktop.csproj",
        "-c",
        "Debug"
      ],
      "dependsOn": "kill-kava",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
