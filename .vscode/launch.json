{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Kava (Debug)",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/Kava/src/Kava.Desktop/Kava.Desktop.csproj"
